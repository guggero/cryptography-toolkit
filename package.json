{
  "name": "cryptography-toolkit",
  "version": "1.3.0",
  "main": "browserify.js",
  "repository": "https://github.com/guggero/cryptography-toolkit.git",
  "author": "Oliver Gugger <gugger@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "aez": "^0.0.1",
    "bip39": "^2.3.0",
    "browserify": "^17.0.0",
    "btcutil-js": "^0.4.0",
    "fast-crc32c": "^1.0.4",
    "google-protobuf": "^3.7.1",
    "grunt": "^1.0.4",
    "grunt-angular-templates": "^1.1.0",
    "grunt-cli": "^1.3.2",
    "husky": "^2.1.0",
    "macaroon": "git+https://github.com/guggero/js-macaroon.git#3149414d2e21895a086b1851b64047ac027b19cb",
    "pbkdf2": "^3.0.13",
    "scrypt-js": "^3.0.0",
    "secrets.js-grempe": "^1.1.0"
  },
  "scripts": {
    "prebrowserify": "cp -f node_modules/btcutil-js/dist/btcutil.wasm libs/wasm/btcutil.wasm && cp -f node_modules/btcutil-js/dist/neutrino-worker.js libs/wasm/neutrino-worker.js",
    "browserify": "browserify -o libs/js/bitcoin.js browserify.js --standalone bitcoin",
    "templates": "grunt ngtemplates",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "check:fresh": "yarn templates && yarn browserify && git diff --exit-code -- libs/templates.js libs/js/bitcoin.js libs/wasm/btcutil.wasm",
    "maketargz": "tar --exclude=release --exclude=.idea --exclude=node_modules -czvf release/cryptography-toolkit.offline.v$npm_package_version.tar.gz *",
    "release": "rm -rf release && mkdir release && yarn maketargz && cd release && sha256sum -b * > cryptography-toolkit.offline.v$npm_package_version.sum",
    "sign": "gpg --clearsign release/cryptography-toolkit.offline.v$npm_package_version.sum"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn browserify && yarn templates && git add ."
    }
  }
}
